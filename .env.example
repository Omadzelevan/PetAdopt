# App
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
SERVER_PUBLIC_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8888

# Security
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d

# Database
DATABASE_URL="mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/petadopt?retryWrites=true&w=majority&appName=PetAdopt"

# Seed admin
ADMIN_EMAIL=admin@petadopt.local
ADMIN_PASSWORD=Admin12345!

# Optional SMTP (if omitted, email verification link will be logged in console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PetAdopt <no-reply@petadopt.local>

# Optional web push
VAPID_SUBJECT=mailto:admin@petadopt.local
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Frontend
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000
