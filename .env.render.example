# Render backend environment
NODE_ENV=production
PORT=10000
DATABASE_URL=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/petadopt?retryWrites=true&w=majority&appName=PetAdopt
JWT_SECRET=SET_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d
SERVER_PUBLIC_URL=https://YOUR-RENDER-SERVICE.onrender.com
CLIENT_URL=https://YOUR-NETLIFY-SITE.netlify.app
CORS_ORIGINS=https://YOUR-NETLIFY-SITE.netlify.app
ADMIN_EMAIL=admin@petadopt.local
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PetAdopt <no-reply@petadopt.local>
VAPID_SUBJECT=mailto:admin@yourdomain.com
VAPID_PUBLIC_KEY=SET_YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=SET_YOUR_VAPID_PRIVATE_KEY
